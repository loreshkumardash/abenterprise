{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Git Save & Push",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                "if(Test-Path .git/index.lock){Remove-Item .git/index.lock}; git add .; git commit -m \"auto update\"; git push"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always"
            },
            "problemMatcher": []
        }
    ]
}